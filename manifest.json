{
  "manifest_version": 3,
  "name": "MockAPI Data Generator",
  "version": "1.0.1",
  "description": "Generate mock JSON API data from any template. Choose count, wrap type, and copy or download instantly.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}